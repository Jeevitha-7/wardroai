{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "*.json",
      "*.js",
      "frontend/index.html",
      "frontend/package.json",
      "frontend/src/**/*.{css,ts,tsx}",
      ".specify/**/*.md",
      "specs/**/*.md"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  }
}
